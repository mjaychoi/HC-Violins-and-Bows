# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Media Storage
# Production/preview must use durable object storage. Local filesystem storage is development/test only.
STORAGE_TYPE=s3
S3_BUCKET_NAME=your_s3_bucket_name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional
# AWS_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ADDRESSING_STYLE=virtual-hosted-style
# KMS_KEY_ID=your_kms_key_id
UPLOAD_MAX_FILE_SIZE_MB=100
# STORAGE_LOCAL_ROOT=/tmp/app-uploads  # Development/test only when STORAGE_TYPE=local

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=your_database_url
DATABASE_PASSWORD=your_database_password

# External Services (Optional)
SNYK_TOKEN=your_snyk_token
SONAR_TOKEN=your_sonarcloud_token
VERCEL_TOKEN=your_vercel_token
ORG_ID=your_vercel_org_id
PROJECT_ID=your_vercel_project_id

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info

# Error Alerting (Optional)
# Enable webhook notifications for errors
NEXT_PUBLIC_ERROR_WEBHOOK_ENABLED=false
# Webhook URL for error notifications (e.g., Slack, Discord, custom endpoint)
NEXT_PUBLIC_ERROR_WEBHOOK_URL=https://your-webhook-url.com/errors
# Minimum error severity to trigger webhook (LOW, MEDIUM, HIGH, CRITICAL)
NEXT_PUBLIC_ERROR_SEVERITY_THRESHOLD=HIGH

# Email Notifications (Phase 3)
# Resend API key for sending email notifications
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx
